<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Quản lý danh mục</h1>
        <a href="/categories/create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Thêm danh mục
        </a>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover" id="categoriesTable">
                    <thead>
                        <tr>
                            <th width="5%">STT</th>
                            <th width="20%">Tên danh mục</th>
                            <th width="25%">Mô tả</th>
                            <th width="15%">Danh mục cha</th>
                            <th width="15%">Hình ảnh</th>
                            <th width="10%">Trạng thái</th>
                            <th width="10%">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% categories.forEach((category, index) => { %>
                            <tr>
                                <td><%= index + 1 %></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <span class="fw-medium"><%= category.name %></span>
                                    </div>
                                </td>
                                <td><%= category.description || 'Không có mô tả' %></td>
                                <td>
                                    <% if(category.parent) { %>
                                        <span class="badge bg-info"><%= category.parent.name %></span>
                                    <% } else { %>
                                        <span class="badge bg-secondary">Danh mục gốc</span>
                                    <% } %>
                                </td>
                                <td>
                                    <% if(category.image) { %>
                                        <img src="<%= category.image %>" alt="<%= category.name %>" class="img-thumbnail" style="max-width: 50px;">
                                    <% } else { %>
                                        <span class="text-muted">Không có ảnh</span>
                                    <% } %>
                                </td>
                                <td>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input status-toggle" type="checkbox" 
                                               data-id="<%= category._id %>"
                                               <%= category.isActive ? 'checked' : '' %>>
                                        <label class="form-check-label">
                                            <span class="badge <%= category.isActive ? 'bg-success' : 'bg-danger' %>">
                                                <%= category.isActive ? 'Hoạt động' : 'Ẩn' %>
                                            </span>
                                        </label>
                                    </div>
                                </td>
                                <td>
                                    <div class="btn-group">
                                        <a href="/categories/edit/<%= category._id %>" class="btn btn-sm btn-info" title="Sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-danger delete-btn" 
                                                data-id="<%= category._id %>" title="Xóa">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<%- contentFor('script') %>
<script>
$(document).ready(function() {
    // Khởi tạo DataTable
    const table = $('#categoriesTable').DataTable({
        language: {
            url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/vi.json'
        },
        order: [[0, 'asc']],
        pageLength: 10,
        responsive: true
    });

    // Xử lý cập nhật trạng thái
    $('.status-toggle').on('change', function() {
        const id = $(this).data('id');
        const isActive = this.checked;
        const badge = $(this).siblings('label').find('.badge');

        if (!confirm('Bạn có chắc chắn muốn thay đổi trạng thái danh mục này?')) {
            // Nếu người dùng không xác nhận, reset về trạng thái cũ
            this.checked = !isActive;
            return;
        }

        $.ajax({
            url: `/categories/${id}/status`,
            method: 'PUT',
            contentType: 'application/json',
            data: JSON.stringify({ isActive: isActive }),
            success: function(response) {
                if (response.success) {
                    // Cập nhật badge
                    badge.removeClass('bg-success bg-danger')
                         .addClass(isActive ? 'bg-success' : 'bg-danger')
                         .text(isActive ? 'Hoạt động' : 'Ẩn');
                    
                    // Hiển thị thông báo
                    alert('Cập nhật trạng thái thành công');
                } else {
                    alert('Có lỗi xảy ra: ' + response.message);
                    // Reset về trạng thái cũ
                    this.checked = !isActive;
                }
            },
            error: function(xhr, status, error) {
                alert('Có lỗi xảy ra khi cập nhật trạng thái');
                // Reset về trạng thái cũ
                this.checked = !isActive;
            }
        });
    });

    // Xử lý xóa danh mục
    $('.delete-btn').on('click', function() {
        const id = $(this).data('id');
        const row = $(this).closest('tr');

        if (confirm('Bạn có chắc chắn muốn xóa danh mục này?')) {
            $.ajax({
                url: `/categories/${id}`,  // Sửa lại URL endpoint
                method: 'DELETE',
                success: function(response) {
                    if (response.success) {
                        // Xóa dòng khỏi bảng
                        table.row(row).remove().draw();
                        // Hiển thị thông báo thành công
                        Swal.fire({
                            icon: 'success',
                            title: 'Thành công!',
                            text: 'Xóa danh mục thành công',
                            timer: 2000,
                            showConfirmButton: false
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Lỗi!',
                            text: response.message || 'Có lỗi xảy ra khi xóa danh mục'
                        });
                    }
                },
                error: function(xhr) {
                    const response = xhr.responseJSON;
                    Swal.fire({
                        icon: 'error',
                        title: 'Lỗi!',
                        text: response?.message || 'Có lỗi xảy ra khi xóa danh mục'
                    });
                }
            });
        }
    });
});
</script> 