<%- include('../layouts/main') %>

<div class="row">
    <div class="col-md-3 mb-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Tổng đơn hàng</h5>
                <h2 class="card-text"><%= totalOrders %></h2>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Doanh thu</h5>
                <h2 class="card-text"><%= totalRevenue.toLocaleString('vi-VN') %>đ</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Sản phẩm</h5>
                <h2 class="card-text"><%= totalProducts %></h2>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Người dùng</h5>
                <h2 class="card-text"><%= totalUsers %></h2>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Đơn hàng gần đây</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Mã đơn</th>
                                <th>Khách hàng</th>
                                <th>Tổng tiền</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% recentOrders.forEach(order => { %>
                                <tr>
                                    <td><%= order.orderNumber %></td>
                                    <td><%= order.user.name %></td>
                                    <td><%= order.totalAmount.toLocaleString('vi-VN') %>đ</td>
                                    <td>
                                        <span class="badge bg-<%= order.status === 'Đã giao hàng' ? 'success' : 'warning' %>">
                                            <%= order.status %>
                                        </span>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-4">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Sản phẩm bán chạy</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th>Danh mục</th>
                                <th>Đã bán</th>
                                <th>Giá</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% topProducts.forEach(product => { %>
                                <tr>
                                    <td><%= product.name %></td>
                                    <td><%= product.category.name %></td>
                                    <td><%= product.sold %></td>
                                    <td><%= product.price.toLocaleString('vi-VN') %>đ</td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div> 